Step 1: Install Docker & KinD
# 1. Download KinD binary
curl -Lo /usr/local/bin/kind https://kind.sigs.k8s.io/dl/v0.23.0/kind-linux-amd64
chmod +x /usr/local/bin/kind

# 2. Make sure Docker is running and uses your 80G space
systemctl start docker


Step 2: install Docker :
# 1. Install required helper tools
dnf install -y yum-utils

# 2. Add the official Docker CE repository
yum-config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo

# 3. Install Docker Engine
dnf install -y docker-ce docker-ce-cli containerd.io



